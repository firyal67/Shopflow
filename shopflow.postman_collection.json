{
  "info": {
    "name": "ShopFlow API",
    "description": "Collection complète ShopFlow — tous les endpoints REST",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8082" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (Customer)",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/auth/register",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"email\":\"client@test.com\",\"motDePasse\":\"Test1234\",\"prenom\":\"Marie\",\"nom\":\"Martin\",\"role\":\"CUSTOMER\"}"}
          }
        },
        {
          "name": "Register (Seller)",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/auth/register",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"email\":\"vendeur@test.com\",\"motDePasse\":\"Test1234\",\"prenom\":\"Jean\",\"nom\":\"Dupont\",\"role\":\"SELLER\",\"nomBoutique\":\"Tech Store\"}"}
          }
        },
        {
          "name": "Login",
          "event": [{"listen": "test", "script": {"exec": ["var r = pm.response.json();", "pm.collectionVariables.set('accessToken', r.accessToken);", "pm.collectionVariables.set('refreshToken', r.refreshToken);"]}}],
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/auth/login",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"email\":\"client@test.com\",\"motDePasse\":\"Test1234\"}"}
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/auth/refresh",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"refreshToken\":\"{{refreshToken}}\"}"}
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/auth/logout",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "body": {"mode": "raw", "raw": "{\"refreshToken\":\"{{refreshToken}}\"}"}
          }
        }
      ]
    },
    {
      "name": "Products",
      "item": [
        {
          "name": "Get All Products (paginated)",
          "request": {"method": "GET", "url": "{{baseUrl}}/api/products?page=0&size=12&sort=dateCreation,desc"}
        },
        {
          "name": "Get Products with Filters",
          "request": {"method": "GET", "url": "{{baseUrl}}/api/products?categoryId=1&prixMin=10&prixMax=500&promo=true"}
        },
        {
          "name": "Get Product by ID",
          "request": {"method": "GET", "url": "{{baseUrl}}/api/products/1"}
        },
        {
          "name": "Search Products",
          "request": {"method": "GET", "url": "{{baseUrl}}/api/products/search?q=iphone"}
        },
        {
          "name": "Top Selling",
          "request": {"method": "GET", "url": "{{baseUrl}}/api/products/top-selling"}
        },
        {
          "name": "Create Product (SELLER)",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/products",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "body": {"mode": "raw", "raw": "{\"nom\":\"Nouveau Produit\",\"description\":\"Description\",\"prix\":49.99,\"stock\":20,\"images\":[\"https://example.com/img.jpg\"],\"categoryIds\":[1],\"variants\":[{\"attribut\":\"Taille\",\"valeur\":\"M\",\"stockSupplementaire\":10,\"prixDelta\":0}]}"}
          }
        },
        {
          "name": "Update Product (SELLER)",
          "request": {
            "method": "PUT", "url": "{{baseUrl}}/api/products/1",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "body": {"mode": "raw", "raw": "{\"nom\":\"Produit Modifie\",\"prix\":59.99,\"stock\":15,\"images\":[],\"categoryIds\":[1]}"}
          }
        },
        {
          "name": "Deactivate Product (SELLER)",
          "request": {
            "method": "DELETE", "url": "{{baseUrl}}/api/products/1",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}]
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "Get Category Tree",
          "request": {"method": "GET", "url": "{{baseUrl}}/api/categories"}
        },
        {
          "name": "Create Category (ADMIN)",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/categories",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "body": {"mode": "raw", "raw": "{\"nom\":\"Nouvelle Categorie\",\"description\":\"Description\"}"}
          }
        },
        {
          "name": "Update Category (ADMIN)",
          "request": {
            "method": "PUT", "url": "{{baseUrl}}/api/categories/1",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "body": {"mode": "raw", "raw": "{\"nom\":\"Categorie Modifiee\",\"description\":\"Nouvelle description\"}"}
          }
        },
        {
          "name": "Delete Category (ADMIN)",
          "request": {
            "method": "DELETE", "url": "{{baseUrl}}/api/categories/1",
            "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}]
          }
        }
      ]
    },
    {
      "name": "Cart",
      "item": [
        {
          "name": "Get Cart",
          "request": {"method": "GET", "url": "{{baseUrl}}/api/cart", "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}]}
        },
        {
          "name": "Add Item to Cart",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/cart/items",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "body": {"mode": "raw", "raw": "{\"productId\":1,\"quantite\":2}"}
          }
        },
        {
          "name": "Update Cart Item Quantity",
          "request": {
            "method": "PUT", "url": "{{baseUrl}}/api/cart/items/1",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "body": {"mode": "raw", "raw": "{\"quantite\":3}"}
          }
        },
        {
          "name": "Remove Cart Item",
          "request": {"method": "DELETE", "url": "{{baseUrl}}/api/cart/items/1", "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}]}
        },
        {
          "name": "Apply Coupon",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/cart/coupon",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "body": {"mode": "raw", "raw": "{\"code\":\"BIENVENUE10\"}"}
          }
        },
        {
          "name": "Remove Coupon",
          "request": {"method": "DELETE", "url": "{{baseUrl}}/api/cart/coupon", "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}]}
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Place Order",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/orders",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "body": {"mode": "raw", "raw": "{\"addressId\":1}"}
          }
        },
        {
          "name": "Get Order by ID",
          "request": {"method": "GET", "url": "{{baseUrl}}/api/orders/1", "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}]}
        },
        {
          "name": "Get My Orders",
          "request": {"method": "GET", "url": "{{baseUrl}}/api/orders/my", "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}]}
        },
        {
          "name": "Get All Orders (ADMIN)",
          "request": {"method": "GET", "url": "{{baseUrl}}/api/orders", "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}]}
        },
        {
          "name": "Update Order Status (SELLER/ADMIN)",
          "request": {
            "method": "PUT", "url": "{{baseUrl}}/api/orders/1/status",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "body": {"mode": "raw", "raw": "{\"statut\":\"PAID\"}"}
          }
        },
        {
          "name": "Cancel Order",
          "request": {"method": "PUT", "url": "{{baseUrl}}/api/orders/1/cancel", "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}]}
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Post Review (CUSTOMER)",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/reviews",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "body": {"mode": "raw", "raw": "{\"productId\":1,\"note\":5,\"commentaire\":\"Excellent produit !\"}"}
          }
        },
        {
          "name": "Get Product Reviews",
          "request": {"method": "GET", "url": "{{baseUrl}}/api/reviews/product/1"}
        },
        {
          "name": "Approve Review (ADMIN)",
          "request": {"method": "PUT", "url": "{{baseUrl}}/api/reviews/1/approve", "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}]}
        },
        {
          "name": "Get Pending Reviews (ADMIN)",
          "request": {"method": "GET", "url": "{{baseUrl}}/api/reviews/pending", "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}]}
        },
        {
          "name": "Get My Reviews (CUSTOMER)",
          "request": {"method": "GET", "url": "{{baseUrl}}/api/reviews/my", "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}]}
        }
      ]
    },
    {
      "name": "Coupons",
      "item": [
        {
          "name": "Create Coupon (ADMIN)",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/coupons",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "body": {"mode": "raw", "raw": "{\"code\":\"SUMMER25\",\"type\":\"PERCENT\",\"valeur\":25,\"usagesMax\":100,\"actif\":true}"}
          }
        },
        {
          "name": "Validate Coupon",
          "request": {"method": "GET", "url": "{{baseUrl}}/api/coupons/validate/BIENVENUE10"}
        },
        {
          "name": "Update Coupon (ADMIN)",
          "request": {
            "method": "PUT", "url": "{{baseUrl}}/api/coupons/1",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "body": {"mode": "raw", "raw": "{\"code\":\"BIENVENUE10\",\"type\":\"PERCENT\",\"valeur\":15,\"actif\":true}"}
          }
        },
        {
          "name": "Delete Coupon (ADMIN)",
          "request": {"method": "DELETE", "url": "{{baseUrl}}/api/coupons/1", "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}]}
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Admin Dashboard",
          "request": {"method": "GET", "url": "{{baseUrl}}/api/dashboard/admin", "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}]}
        },
        {
          "name": "Seller Dashboard",
          "request": {"method": "GET", "url": "{{baseUrl}}/api/dashboard/seller", "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}]}
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get My Profile",
          "request": {"method": "GET", "url": "{{baseUrl}}/api/users/me", "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}]}
        },
        {
          "name": "Get All Users (ADMIN)",
          "request": {"method": "GET", "url": "{{baseUrl}}/api/users", "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}]}
        },
        {
          "name": "Toggle User Status (ADMIN)",
          "request": {"method": "PUT", "url": "{{baseUrl}}/api/users/1/toggle-status", "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}]}
        },
        {
          "name": "Get My Addresses",
          "request": {"method": "GET", "url": "{{baseUrl}}/api/users/me/addresses", "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}]}
        },
        {
          "name": "Add Address",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/users/me/addresses",
            "header": [{"key": "Content-Type", "value": "application/json"}, {"key": "Authorization", "value": "Bearer {{accessToken}}"}],
            "body": {"mode": "raw", "raw": "{\"rue\":\"12 rue de la Paix\",\"ville\":\"Paris\",\"codePostal\":\"75001\",\"pays\":\"France\",\"principal\":true}"}
          }
        },
        {
          "name": "Delete Address",
          "request": {"method": "DELETE", "url": "{{baseUrl}}/api/users/me/addresses/1", "header": [{"key": "Authorization", "value": "Bearer {{accessToken}}"}]}
        },
        {
          "name": "Request Password Reset",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/users/password-reset/request",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"email\":\"client@test.com\"}"}
          }
        },
        {
          "name": "Confirm Password Reset",
          "request": {
            "method": "POST", "url": "{{baseUrl}}/api/users/password-reset/confirm",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {"mode": "raw", "raw": "{\"token\":\"TOKEN_ICI\",\"newPassword\":\"NewPass1234\"}"}
          }
        }
      ]
    }
  ]
}
